## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options
.vs/

# JetBrains Rider
.idea/
*.sln.iml

# Storage and uploads
storage/
uploads/
outputs/
temp/

# ═══════════════════════════════════════════════════════════════════════════
# SEGURANÇA - CREDENCIAIS E DADOS SENSÍVEIS
# ═══════════════════════════════════════════════════════════════════════════

# Environment variables (IMPORTANTE!)
.env
.env.*
!.env.example

# User Secrets setup scripts
setup-secrets*.ps1
*secrets*.json

# Development appsettings (podem conter credenciais locais)
**/appsettings.Development.json
**/appsettings.Local.json

# NÃO IGNORAR Production (mas devem usar variáveis de ambiente)
# **/appsettings.Production.json

# ═══════════════════════════════════════════════════════════════════════════

# Docker volumes
postgres_data/
redis_data/
rabbitmq_data/
seq_data/

# OS files
.DS_Store
Thumbs.db

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# NuGet
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/

# VS Code
.vscode/

# Temporary files
*.tmp
*.temp
*.log
*.pid
*.seed
*.pid.lock

# FFmpeg outputs (arquivos de teste)
*.mp4
*.avi
*.mov
*.mkv
*.zip

# Backup files
*.bak
*.backup