# ========================================
# FIAP X - CONFIGURAÇÕES DE AMBIENTE
# ========================================
# 
# IMPORTANTE:
# 1. Copie este arquivo: cp .env.example .env
# 2. Altere as senhas e secrets abaixo
# 3. NUNCA commite o arquivo .env com dados reais!
#
# ========================================

# ========================================
# POSTGRESQL DATABASE
# ========================================

# Nome do banco de dados
POSTGRES_DB=fiapx_db

# Usuário do PostgreSQL
POSTGRES_USER=fiapx_user

# ⚠️ ALTERE ESTA SENHA!
# Mínimo 12 caracteres, use letras, números e símbolos
POSTGRES_PASSWORD=SuaSenhaPostgreSQL_Segura123!

# Connection String completa
# Formato: Host=<host>;Port=<porta>;Database=<db>;Username=<user>;Password=<senha>
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=fiapx_db;Username=fiapx_user;Password=SuaSenhaPostgreSQL_Segura123!

# ========================================
# RABBITMQ MESSAGING
# ========================================

# Usuário do RabbitMQ
RABBITMQ_DEFAULT_USER=fiapx

# ⚠️ ALTERE ESTA SENHA!
# Mínimo 12 caracteres
RABBITMQ_DEFAULT_PASS=SuaSenhaRabbitMQ_Segura456!

# Configurações de conexão
MessageBroker__Host=rabbitmq
MessageBroker__VirtualHost=/
MessageBroker__Username=fiapx
MessageBroker__Password=SuaSenhaRabbitMQ_Segura456!

# Configurações de retry (não alterar)
MessageBroker__RetryCount=3
MessageBroker__RetryInterval=5

# ========================================
# JWT AUTHENTICATION
# ========================================

# ⚠️ ALTERE ESTE SECRET!
# MÍNIMO 32 caracteres, use caracteres aleatórios
# Gere um novo: openssl rand -base64 32
JWT__Secret=SuaChaveSecretaSuperSeguraDeNoMinimo32Caracteres123!

# Issuer (quem emite o token)
JWT__Issuer=FiapX

# Audience (para quem o token é válido)
JWT__Audience=FiapXUsers

# Tempo de expiração do token em minutos
# Padrão: 60 minutos (1 hora)
JWT__ExpirationMinutes=60

# ========================================
# REDIS CACHE
# ========================================

# Connection String do Redis
# Formato: <host>:<porta>
Redis__ConnectionString=redis:6379

# TTL padrão do cache em minutos (opcional)
# Padrão: 5 minutos
Redis__DefaultExpirationMinutes=5

# ========================================
# STORAGE (FILE SYSTEM)
# ========================================

# Pasta base para armazenamento
# Docker: /storage (montado como volume)
# Local: ./storage
Storage__BasePath=/storage

# Subpastas
Storage__UploadsFolder=uploads
Storage__OutputsFolder=outputs
Storage__TempFolder=temp

# Tamanho máximo de arquivo em bytes
# 2147483648 bytes = 2 GB
Storage__MaxFileSizeBytes=2147483648

# Extensões permitidas (separadas por vírgula)
Storage__AllowedExtensions=mp4,avi,mov,mkv,wmv,flv,webm,m4v

# ========================================
# FFMPEG PROCESSING
# ========================================

# Taxa de frames por segundo para extração
# 1 = extrai 1 frame por segundo
FFmpeg__FrameRate=1

# Formato de saída das imagens
# Opções: jpg, png
FFmpeg__OutputFormat=jpg

# Qualidade das imagens
# Opções: low, medium, high
FFmpeg__Quality=high

# Timeout de processamento em minutos
# Padrão: 10 minutos
FFmpeg__TimeoutMinutes=10

# ========================================
# TELEGRAM NOTIFICATIONS (OPCIONAL)
# ========================================

# Habilitar notificações Telegram
# true = envia notificações
# false = desabilita (padrão para desenvolvimento)
Telegram__Enabled=false

# Token do Bot Telegram
# Obtenha com @BotFather no Telegram
# Exemplo: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# ⚠️ Só necessário se Enabled=true
Telegram__BotToken=

# ID do Chat para enviar notificações
# Obtenha com @userinfobot no Telegram
# Exemplo: 123456789
# ⚠️ Só necessário se Enabled=true
Telegram__ChatId=

# ========================================
# SEQ LOGGING
# ========================================

# URL do servidor Seq
# Docker: http://seq:5341
# Local: http://localhost:5341
Seq__ServerUrl=http://seq:5341

# API Key do Seq (opcional, para produção)
Seq__ApiKey=

# ========================================
# SERILOG
# ========================================

# Nível mínimo de log
# Opções: Verbose, Debug, Information, Warning, Error, Fatal
Serilog__MinimumLevel__Default=Information

# Override para logs do Microsoft
# Reduz verbosidade de logs internos do ASP.NET
Serilog__MinimumLevel__Override__Microsoft=Warning
Serilog__MinimumLevel__Override__System=Warning
Serilog__MinimumLevel__Override__Microsoft.EntityFrameworkCore=Warning

# ========================================
# ASPNET CORE
# ========================================

# Ambiente de execução
# Opções: Development, Staging, Production
ASPNETCORE_ENVIRONMENT=Production

# URLs da aplicação (Docker)
ASPNETCORE_URLS=http://+:8080

# Habilitar developer exception page
# true = mostra erros detalhados (apenas Development!)
# false = mostra erros genéricos (Production)
ASPNETCORE_DETAILEDERRORS=false

# ========================================
# HEALTH CHECKS
# ========================================

# Timeout para health checks em segundos
HealthChecks__TimeoutSeconds=30

# Intervalo entre checks em segundos
HealthChecks__IntervalSeconds=60

# ========================================
# CORS (DESENVOLVIMENTO)
# ========================================

# Origens permitidas (separadas por vírgula)
# * = permite todas (APENAS DESENVOLVIMENTO!)
# Produção: https://seudominio.com,https://app.seudominio.com
Cors__AllowedOrigins=*

# ========================================
# RATE LIMITING (FUTURO - v2.0)
# ========================================

# Máximo de requisições por minuto
# RateLimit__RequestsPerMinute=100

# Máximo de uploads por hora
# RateLimit__UploadsPerHour=10

# ========================================
# PROMETHEUS METRICS (FUTURO - v2.0)
# ========================================

# Habilitar métricas Prometheus
# Prometheus__Enabled=false

# Porta para métricas
# Prometheus__Port=9090

# ========================================
# EXEMPLO DE USO NO DOCKER COMPOSE
# ========================================
#
# No docker-compose.yml, use assim:
#
# services:
#   api:
#     env_file:
#       - .env
#     environment:
#       - ConnectionStrings__DefaultConnection=${ConnectionStrings__DefaultConnection}
#       - JWT__Secret=${JWT__Secret}
#
# ========================================

# ========================================
# NOTAS IMPORTANTES
# ========================================
#
# 1. SEGURANÇA:
#    - NUNCA commite .env com dados reais
#    - Use senhas fortes (min 12 caracteres)
#    - Gere secrets aleatórios para JWT
#    - Em produção, use Azure Key Vault, AWS Secrets Manager, etc
#
# 2. DESENVOLVIMENTO:
#    - Telegram__Enabled=false (economiza configuração)
#    - ASPNETCORE_ENVIRONMENT=Development (mostra erros)
#    - Cors__AllowedOrigins=* (permite todas origens)
#
# 3. PRODUÇÃO:
#    - Telegram__Enabled=true (notificações importantes)
#    - ASPNETCORE_ENVIRONMENT=Production
#    - Cors__AllowedOrigins=https://seudominio.com
#    - Use HTTPS obrigatório
#    - Configure rate limiting
#
# 4. TAMANHOS:
#    - 2GB max por vídeo (padrão)
#    - Ajuste Storage__MaxFileSizeBytes se necessário
#
# 5. PERFORMANCE:
#    - Redis TTL padrão: 5 minutos
#    - FFmpeg timeout: 10 minutos
#    - Ajuste conforme necessário
#
# ========================================
