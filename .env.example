# ═══════════════════════════════════════════════════════════════════════════
# EXEMPLO DE CONFIGURAÇÃO - DOCKER PRODUCTION
# ═══════════════════════════════════════════════════════════════════════════
# 
# 📝 COMO USAR:
# 1. Copie este arquivo para .env (na raiz do projeto)
# 2. Substitua os valores pelos seus reais
# 3. Nunca commite o arquivo .env no Git!
# 
# ═══════════════════════════════════════════════════════════════════════════

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────
POSTGRES_CONNECTION_STRING=Host=postgres;Port=5432;Database=fiapx_db;Username=SEU_USER;Password=SUA_SENHA
POSTGRES_DB=fiapx_db
POSTGRES_USER=seu_usuario
POSTGRES_PASSWORD=sua_senha_segura

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_CONNECTION_STRING=redis:6379

# ─── RabbitMQ ───────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_USERNAME=seu_usuario
RABBITMQ_PASSWORD=sua_senha_segura
RABBITMQ_CONNECTION_STRING=amqp://usuario:senha@rabbitmq:5672/
RABBITMQ_DEFAULT_USER=seu_usuario
RABBITMQ_DEFAULT_PASS=sua_senha_segura

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=sua_chave_secreta_jwt_aqui_minimo_32_caracteres

# ─── Telegram Notifications ─────────────────────────────────────────────────
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=seu-bot-token-do-botfather
TELEGRAM_CHAT_ID=seu-chat-id-numerico
